using System;
class Program
{
    static void Main()
    {
        Console.Write("enter:");
        int age=Convert.ToInt32(Console.ReadLine()!);

        if(age<0)
        {
            Console.WriteLine("Invalid age");
        }
        else if(age>=18)
        {
            Console.WriteLine("eligible for voting");
        }
        else
        {
            Console.WriteLine("not eligible for voting");
        }
    }
}