using System;
class Program
{
    static void Main()
    {
        Console.Write("enter:");
        int n=Convert.ToInt32(Console.ReadLine());
        int rev=0;
        while(n>0)
        {
            int rem=n%10;
            rev=rev*10+rem;
            n=n/10;
        }
        Console.WriteLine($"Reverse:{rev}");
    }
}