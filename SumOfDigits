using System;
class Program
{
    static void Main()
    {
        Console.Write("enter:");
        int n=Convert.ToInt32(Console.ReadLine());
        int sum=0;
        while(n>0)
        {
            int rem=n%10;
            sum=sum+rem;
            n=n/10;
        }
        Console.WriteLine(sum);
    }
}